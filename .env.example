# DNS サーバー基本設定
LISTEN_ADDR=0.0.0.0:53
FILTER_FILE=/etc/iaretis/blocklist.txt
# info: ブロックログ表示, warn: エラーのみ, debug: 全クエリ表示
RUST_LOG=iaretis=info

# DNS ポートのバインドアドレス (WireGuard VPN インターフェース等)
# DNS_BIND_ADDR=10.100.0.1

# DoH (DNS-over-HTTPS) 設定 - 3つ揃えると DoH が有効になる
DOH_LISTEN_ADDR=0.0.0.0:8443
DOH_CERT_PATH=/etc/iaretis/tls/fullchain.pem
DOH_KEY_PATH=/etc/iaretis/tls/privkey.pem

# DoH のドメイン名
# DOH_HOSTNAME=dns.example.com

# DoH のシークレットトークン (openssl rand -hex 16 で生成)
# DOH_SECRET_TOKEN=

# Let's Encrypt 証明書ディレクトリ (compose.prod.yml で使用)
# TLS_CERT_DIR=/etc/letsencrypt/live/example.com
